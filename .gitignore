# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit real keys
.env
.env.local
.env.*.local
# (but DO commit .env.example — template only)
!.env.example

# vercel
.vercel


# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
test
prompt

server.log

# Auto-push daemon (deleted in Phase 2.5 cleanup)
scripts/autopush.log
scripts/autopush.stdout.log

# PWA generated service worker (auto-built by @ducanh2912/next-pwa)
public/sw.js
public/sw.js.map
public/workbox-*.js
public/workbox-*.js.map
public/fallback-*.js

# Prisma (deleted in Phase 2.5, but keep ignore for safety)
/prisma/*.db
/prisma/*.db-journal

# Skills directory (sandbox-only)
/skills/

