# =========================================================
# ScanWise — Environment Variables
# =========================================================
# Copy this file to `.env` (or `.env.local`) and fill in your keys.
# NEVER commit `.env` — it's gitignored.

# ---------- Phase 3 — Supabase (Postgres) ----------
# Create a free project at https://supabase.com
# Project Settings → API → "Project URL" and "anon public" key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (server-only, NEVER expose to client)
# Project Settings → API → "service_role" key
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Phase 3 — Open Food Facts API ----------
# No key needed — OFF is a free, open database.
# Optional: register an app for higher rate limits.
# https://world.openfoodfacts.org/data
OFF_USER_AGENT=ScanWise/0.2.5 (https://github.com/tataiplse18-sketch/Scanwise-X)

# ---------- Phase 5 — Google Gemini API (AI summary) ----------
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ---------- Phase 6 — Optional analytics & monitoring ----------
# PostHog (https://posthog.com) — free tier
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry (https://sentry.io) — error tracking
SENTRY_DSN=

# ---------- Vercel deploy (Phase 8) ----------
# Auto-set by Vercel — no action needed locally
# VERCEL_URL=
# NEXT_PUBLIC_VERCEL_URL=
